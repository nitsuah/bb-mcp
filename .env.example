# Blackboard Learn MCP Server environment
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Blackboard Learn OAuth 2.0 ──────────────────────────────────────────────
# Application credentials from developer.blackboard.com
BB_CLIENT_ID=your_client_id_here
BB_CLIENT_SECRET=your_client_secret_here

# Base URL of your Blackboard Learn instance (or the sandbox)
# Sandbox: https://developer.blackboard.com/portal/displayApi
BB_BASE_URL=https://your-instance.blackboard.com

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3100
LOG_LEVEL=info
PUBLIC_BASE_URL=http://localhost:3100

# ── Metrics ──────────────────────────────────────────────────────────────────
# Optional: Prometheus-compatible push gateway
METRICS_PUSH_URL=

# ── FERPA / Safety ──────────────────────────────────────────────────────────
# Comma-separated list of tool names that require elevated identity verification
RESTRICTED_TOOLS=get_at_risk_students,get_grade_distribution,get_submission_status

# Per-role request limits (auth layer) per rolling minute window
RATE_LIMIT_STUDENT_PER_MINUTE=60
RATE_LIMIT_INSTRUCTOR_PER_MINUTE=120
RATE_LIMIT_ADMIN_PER_MINUTE=180
