{
  "name": "blackboard-learn-mcp",
  "version": "0.1.0",
  "description": "MCP server wrapping the Blackboard Learn REST API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bb-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "docker:test-image": "docker build --target test -t bb-mcp:test .",
    "docker:lint": "docker run --rm bb-mcp:test npm run lint",
    "docker:test": "docker run --rm bb-mcp:test npm test",
    "docker:coverage": "docker run --rm bb-mcp:test npm run test:coverage",
    "docker:audit": "docker run --rm bb-mcp:test npm audit --audit-level=high",
    "docker:complexity": "docker run --rm bb-mcp:test npm run metrics:complexity",
    "docker:docs": "docker run --rm bb-mcp:test npm run metrics:docs",
    "docker:quality": "npm run docker:test-image && npm run docker:lint && npm run docker:coverage && npm run docker:audit && npm run docker:complexity && npm run docker:docs",
    "metrics:complexity": "node scripts/metrics-complexity.mjs",
    "metrics:docs": "node scripts/metrics-doc-coverage.mjs",
    "test": "vitest run --config config/vitest.config.ts",
    "test:coverage": "vitest run --config config/vitest.config.ts --coverage",
    "test:watch": "vitest --config config/vitest.config.ts",
    "lint": "eslint src --ext .ts --config config/eslint.config.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  }
}
