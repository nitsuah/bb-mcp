{
  "name": "blackboard-learn-mcp",
  "version": "0.1.0",
  "description": "MCP server wrapping the Blackboard Learn REST API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bb-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "dotenv": "^17.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^1.0.0"
  }
}
